{
  "name": "@petbee/eslint-config",
  "version": "3.0.10",
  "description": "Petbee's eslint config",
  "keywords": [
    "eslint",
    "config",
    "petbee"
  ],
  "homepage": "https://github.com/petbee/typescript",
  "license": "MIT",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.mjs",
      "types": "./index.d.ts"
    },
    "./legacy": "./index.js"
  },
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/petbee/typescript.git",
    "directory": "packages/eslint-config"
  },
  "scripts": {
    "eslint-check": "eslint-config-prettier index.js",
    "dump-config": "eslint-config-prettier index.js > config-dump.json",
    "format": "prettier --ignore-path='.gitignore' --list-different --write .",
    "format:check": "prettier --ignore-path='.gitignore' --check .",
    "lint": "eslint '{src,tests}/**/*.{ts,tsx}'"
  },
  "eslintConfig": {
    "extends": [
      "petbee"
    ]
  },
  "prettier": "@petbee/prettier-config",
  "bugs": {
    "url": "https://github.com/petbee/typescript/issues"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.32",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "confusing-browser-globals": "^1.0.11",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript-eslint": "^8.59.2"
  },
  "peerDependencies": {
    "eslint": "^9.39.1 || ^10.0.0",
    "prettier": ">=3.0.0",
    "typescript": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": false
    },
    "prettier": {
      "optional": false
    },
    "typescript": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "prettier": "3.8.3",
    "react": "19.2.6",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
